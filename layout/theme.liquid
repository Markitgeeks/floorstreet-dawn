<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" dir="{{ settings.text_direction | default: 'ltr' }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">
  <meta name="theme-color" content="{{ settings.color_accent }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {%- if settings.custom_font_url != blank -%}
    <link href="{{ settings.custom_font_url }}" rel="stylesheet">
  {%- endif -%}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'custom-floorstreet.css' | asset_url | stylesheet_tag }}

  {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
    <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
  {%- endunless -%}

  {{ content_for_header }}

  <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a class="skip-to-content-link visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_text' | t }}
  </a>

  {% sections 'header-group' %}

  <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  <script src="{{ 'custom-floorstreet.js' | asset_url }}" defer></script>

  {%- if request.page_type == 'index' -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ shop.url }}/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }}
        {%- if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_tiktok_link != blank or settings.social_youtube_link != blank -%}
        ,"sameAs": [
          {%- if settings.social_facebook_link != blank %}"{{ settings.social_facebook_link }}"{% endif -%}
          {%- if settings.social_instagram_link != blank %},{{ settings.social_instagram_link | json }}{% endif -%}
          {%- if settings.social_tiktok_link != blank %},{{ settings.social_tiktok_link | json }}{% endif -%}
          {%- if settings.social_youtube_link != blank %},{{ settings.social_youtube_link | json }}{% endif -%}
        ]
        {%- endif -%}
      }
    </script>
  {%- endif -%}
</body>
</html>
