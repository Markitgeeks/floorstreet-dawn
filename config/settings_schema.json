    "theme_documentation_url": "https://floorstreet.co.uk",
    "theme_support_url": "https://floorstreet.co.uk/pages/contact"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color",
        "default": "#1c1c1c"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_sale",
        "label": "Sale badge color",
        "default": "#c62828"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading font",
        "default": "montserrat_n6"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "montserrat_n4"
      },
      {
        "type": "text",
        "id": "custom_font_url",
        "label": "Custom font URL (optional)",
        "info": "External Google Fonts or other font service URL"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "32x32px .png recommended"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
