{
  "sections": {
    "main-product": {
      "type": "fs-product-page",
      "settings": {
        "show_dynamic_checkout": true,
        "show_vendor": true
      },
      "blocks": {
        "description": {
          "type": "description",
          "settings": {
            "heading": "Description"
          }
        },
        "specifications": {
          "type": "specifications",
          "settings": {
            "heading": "Specifications"
          }
        },
        "shipping": {
          "type": "shipping",
          "settings": {
            "heading": "Shipping & Returns",
            "content": "<p>Free nationwide delivery on all orders. Most orders arrive within 3-5 working days. 30-day returns policy on unopened products.</p>"
          }
        }
      },
      "block_order": ["description", "specifications", "shipping"]
    },
    "related-products": {
      "type": "fs-featured-collection",
      "settings": {
        "heading": "You May Also Like",
        "products_to_show": 4,
        "columns_desktop": 4,
        "show_sale_badge": true,
        "show_secondary_image": true,
        "show_quick_add": false,
        "show_view_all": false
      }
    }
  },
  "order": ["main-product", "related-products"]
}
