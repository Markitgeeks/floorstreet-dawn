{%- liquid
  assign show_payment = section.settings.show_payment_icons
  assign show_social = section.settings.show_social
-%}

<footer class="fs-footer" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="fs-footer__grid">
      {%- for block in section.blocks -%}
        <div class="fs-footer__column" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'menu' -%}
              {%- if block.settings.heading != blank -%}
                <h4>{{ block.settings.heading }}</h4>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="fs-footer__links">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.heading != blank -%}
                <h4>{{ block.settings.heading }}</h4>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div style="font-size: var(--fs-font-size-sm); color: var(--fs-color-text-secondary); line-height: 1.7;">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
              {%- if show_social -%}
                <div class="fs-footer__social">
                  {%- if settings.social_instagram_link != blank -%}
                    <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                      </svg>
                    </a>
                  {%- endif -%}
                  {%- if settings.social_tiktok_link != blank -%}
                    <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.11v-3.49a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V9.17a8.16 8.16 0 004.76 1.53V7.25a4.82 4.82 0 01-1-.56z"/>
                      </svg>
                    </a>
                  {%- endif -%}
                  {%- if settings.social_youtube_link != blank -%}
                    <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                      </svg>
                    </a>
                  {%- endif -%}
                  {%- if settings.social_facebook_link != blank -%}
                    <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'brand' -%}
              {%- if section.settings.footer_logo != blank -%}
                <div style="margin-bottom: var(--fs-space-md);">
                  {{ section.settings.footer_logo | image_url: width: 200 | image_tag: loading: 'lazy', alt: shop.name }}
                </div>
              {%- else -%}
                <h4>{{ shop.name }}</h4>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div style="font-size: var(--fs-font-size-sm); color: var(--fs-color-text-secondary); line-height: 1.7;">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="fs-footer__bottom">
      <p class="fs-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {{ powered_by_link }}
      </p>

      {%- if show_payment -%}
        <div class="fs-footer__payments">
          {{ shop.enabled_payment_types | payment_type_svg_tag }}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "FS Footer",
  "tag": "div",
  "class": "fs-footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true,
      "info": "Links are set in Theme Settings > Social media"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "brand",
      "name": "Brand column",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Brand description",
          "default": "<p>The best flooring company. Fast and free nationwide delivery on every order.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FS Footer",
      "blocks": [
        { "type": "brand" },
        { "type": "menu", "settings": { "heading": "Shop" } },
        { "type": "menu", "settings": { "heading": "Help" } },
        { "type": "text", "settings": { "heading": "Contact Us", "text": "<p>Email: hello@example.com<br>Phone: 0800 000 0000</p>" } }
      ]
    }
  ]
}
{% endschema %}
