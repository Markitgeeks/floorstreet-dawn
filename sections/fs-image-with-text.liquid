{%- liquid
  assign image = section.settings.image
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign button_text = section.settings.button_text
  assign button_url = section.settings.button_url
  assign layout = section.settings.layout
-%}

<section class="fs-section{% if section.settings.remove_top_padding %} fs-section--no-top{% endif %}{% if section.settings.remove_bottom_padding %} fs-section--no-bottom{% endif %}" data-section-id="{{ section.id }}">
  <div class="fs-split{% if layout == 'image_right' %} fs-split--reverse{% endif %}">
    <div class="fs-split__image">
      {%- if image != blank -%}
        {{ image | image_url: width: 1000 | image_tag:
          loading: 'lazy',
          sizes: '(min-width: 1000px) 50vw, 100vw',
          widths: '400,600,800,1000',
          alt: heading
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
    <div class="fs-split__content"
      style="{% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }};{% endif %}{% if section.settings.text_color != blank %}color: {{ section.settings.text_color }};{% endif %}"
    >
      {%- if heading != blank -%}
        <h2{% if section.settings.text_color != blank %} style="color: {{ section.settings.text_color }}"{% endif %}>{{ heading }}</h2>
      {%- endif -%}

      {%- if text != blank -%}
        <div>{{ text }}</div>
      {%- endif -%}

      {%- if button_text != blank -%}
        <a href="{{ button_url }}" class="fs-btn fs-btn--primary">{{ button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FS Image with Text",
  "tag": "div",
  "class": "fs-image-text-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image_left", "label": "Image left" },
        { "value": "image_right", "label": "Image right" }
      ],
      "default": "image_left"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Share your brand story with customers. Describe your products, values, or any unique aspect of your business.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Content background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "checkbox",
      "id": "remove_top_padding",
      "label": "Remove top padding",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "remove_bottom_padding",
      "label": "Remove bottom padding",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "FS Image with Text"
    }
  ]
}
{% endschema %}
