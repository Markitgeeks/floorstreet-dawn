{%- liquid
  assign logo = section.settings.logo
  assign menu = section.settings.menu
  assign menu_right = section.settings.menu_right
-%}

<header class="fs-header" data-section-id="{{ section.id }}">
  <div class="fs-header__inner page-width">
    <!-- Mobile hamburger -->
    <div class="fs-header__hamburger">
      <button class="fs-hamburger-btn" data-open-mobile-nav aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Left nav (desktop) -->
    <nav class="fs-header__nav-left" aria-label="Primary navigation">
      <ul class="fs-nav">
        {%- for link in linklists[menu].links -%}
          <li class="fs-nav__item">
            <a href="{{ link.url }}" class="fs-nav__link"
              {% if link.links.size > 0 %} aria-haspopup="true" aria-expanded="false"{% endif %}>
              {{ link.title }}
            </a>
            {%- if link.links.size > 0 -%}
              <div class="fs-mega-menu">
                {%- comment -%} Group sub-links by first-level children {%- endcomment -%}
                {%- for child_link in link.links -%}
                  <div class="fs-mega-menu__column">
                    <h4>{{ child_link.title }}</h4>
                    {%- if child_link.links.size > 0 -%}
                      <ul class="fs-mega-menu__links">
                        {%- for grandchild in child_link.links -%}
                          <li><a href="{{ grandchild.url }}">{{ grandchild.title }}</a></li>
                        {%- endfor -%}
                      </ul>
                    {%- else -%}
                      <ul class="fs-mega-menu__links">
                        <li><a href="{{ child_link.url }}">View All</a></li>
                      </ul>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Center logo -->
    <div class="fs-header__logo">
      <a href="{{ routes.root_url }}">
        {%- if logo != blank -%}
          {{ logo | image_url: width: 280 | image_tag:
            class: 'fs-header__logo-img',
            loading: 'lazy',
            alt: shop.name
          }}
        {%- else -%}
          <span class="fs-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Right nav (desktop) + icons -->
    <div class="fs-header__nav-right">
      {%- if menu_right != blank -%}
        <nav aria-label="Secondary navigation">
          <ul class="fs-nav">
            {%- for link in linklists[menu_right].links -%}
              <li class="fs-nav__item">
                <a href="{{ link.url }}" class="fs-nav__link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      <div class="fs-header__icons">
        <!-- Search -->
        <a href="{{ routes.search_url }}" class="fs-header__icon" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </a>

        <!-- Account -->
        <a href="{{ routes.account_url }}" class="fs-header__icon" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </a>

        <!-- Cart -->
        <a href="{{ routes.cart_url }}" class="fs-header__icon" aria-label="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
          </svg>
          <span class="fs-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Mobile navigation drawer -->
<div class="fs-mobile-nav-overlay" data-close-mobile-nav></div>
<nav class="fs-mobile-nav" aria-label="Mobile navigation">
  <div class="fs-mobile-nav__header">
    <span class="fs-header__logo-text" style="font-size: 1rem;">{{ shop.name }}</span>
    <button class="fs-mobile-nav__close" data-close-mobile-nav aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <ul class="fs-mobile-nav__list">
    {%- for link in linklists[menu].links -%}
      <li class="fs-mobile-nav__item">
        {%- if link.links.size > 0 -%}
          <a href="#" class="fs-mobile-nav__link" data-toggle-sub>
            {{ link.title }}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </a>
          <div class="fs-mobile-nav__sub">
            <a href="{{ link.url }}">View All {{ link.title }}</a>
            {%- for child in link.links -%}
              <a href="{{ child.url }}">{{ child.title }}</a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="fs-mobile-nav__link">{{ link.title }}</a>
        {%- endif -%}
      </li>
    {%- endfor -%}

    {%- if menu_right != blank -%}
      {%- for link in linklists[menu_right].links -%}
        <li class="fs-mobile-nav__item">
          <a href="{{ link.url }}" class="fs-mobile-nav__link">{{ link.title }}</a>
        </li>
      {%- endfor -%}
    {%- endif -%}
  </ul>
</nav>

{% schema %}
{
  "name": "FS Header",
  "tag": "div",
  "class": "fs-header-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 60,
      "max": 250,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Primary menu (left side)",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "menu_right",
      "label": "Secondary menu (right side)",
      "info": "Optional. Shown on the right of the logo on desktop."
    }
  ],
  "presets": [
    {
      "name": "FS Header"
    }
  ]
}
{% endschema %}
