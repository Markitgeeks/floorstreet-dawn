<section class="fs-newsletter" data-section-id="{{ section.id }}"
  style="{% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }};{% endif %}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p>{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'fs-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="fs-newsletter__form">
        <input
          type="email"
          name="contact[email]"
          class="fs-newsletter__input"
          placeholder="{{ section.settings.placeholder }}"
          required
          autocomplete="email"
          aria-label="Email address"
        >
        <button type="submit" class="fs-newsletter__submit">
          {{ section.settings.button_text }}
        </button>
      </div>

      {%- if form.posted_successfully? -%}
        <p style="margin-top: var(--fs-space-md); color: rgba(255,255,255,0.8);">
          Thanks for subscribing!
        </p>
      {%- endif -%}

      {%- if form.errors -%}
        <p style="margin-top: var(--fs-space-md); color: #ff6b6b;">
          {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
        </p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "FS Newsletter",
  "tag": "div",
  "class": "fs-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join Our Mailing List"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Subscribe for exclusive offers, new arrivals, and flooring tips."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1c1c1c"
    }
  ],
  "presets": [
    {
      "name": "FS Newsletter"
    }
  ]
}
{% endschema %}
