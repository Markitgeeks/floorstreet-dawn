{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 24
  assign columns = section.settings.columns_desktop | default: 4
  assign show_sale_badge = section.settings.show_sale_badge
  assign show_secondary_image = section.settings.show_secondary_image
-%}

<section class="fs-section" data-section-id="{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.enable_sorting or section.settings.enable_filtering -%}
      <div class="fs-collection-toolbar">
        {%- if section.settings.enable_filtering -%}
          <div class="fs-collection-toolbar__filters">
            {%- for filter in collection.filters -%}
              <details class="fs-filter">
                <summary class="fs-filter__toggle">
                  {{ filter.label }}
                  <svg width="12" height="12" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="fs-filter__dropdown">
                  {%- case filter.type -%}
                    {%- when 'list' -%}
                      <ul class="fs-filter__list">
                        {%- for value in filter.values -%}
                          <li>
                            <label class="fs-filter__option">
                              <input type="checkbox"
                                name="{{ value.param_name }}"
                                value="{{ value.value }}"
                                {% if value.active %}checked{% endif %}
                                {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              >
                              <span>{{ value.label }} ({{ value.count }})</span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- when 'price_range' -%}
                      <div class="fs-filter__price-range">
                        <input type="number" name="{{ filter.min_value.param_name }}" placeholder="From" min="0" value="{{ filter.min_value.value | money_without_currency }}">
                        <span>—</span>
                        <input type="number" name="{{ filter.max_value.param_name }}" placeholder="To" min="0" value="{{ filter.max_value.value | money_without_currency }}">
                      </div>
                  {%- endcase -%}
                </div>
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.enable_sorting -%}
          <div class="fs-collection-toolbar__sort">
            <label for="fs-sort-select" class="visually-hidden">Sort by</label>
            <select id="fs-sort-select" class="fs-sort-select" onchange="window.location.href = this.value;">
              {%- for option in collection.sort_options -%}
                <option value="{{ option.url }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="fs-product-grid" style="--fs-product-columns-desktop: {{ columns }};">
      {%- paginate collection.products by products_per_page -%}
        {%- for product in collection.products -%}
          {% render 'fs-product-card',
            product: product,
            show_sale_badge: show_sale_badge,
            show_secondary_image: show_secondary_image,
            show_quick_add: false
          %}
        {%- endfor -%}
      {%- endpaginate -%}
    </div>

    {%- paginate collection.products by products_per_page -%}
      {%- if paginate.pages > 1 -%}
        <nav class="fs-pagination" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="fs-pagination__link" aria-label="Previous page">&laquo; Prev</a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="fs-pagination__link">{{ part.title }}</a>
            {%- else -%}
              <span class="fs-pagination__link is-current" aria-current="page">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="fs-pagination__link" aria-label="Next page">Next &raquo;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</section>

{% schema %}
{
  "name": "FS Collection Grid",
  "tag": "div",
  "class": "fs-collection-grid-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show second image on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    }
  ]
}
{% endschema %}
