<section class="fs-section" data-section-id="{{ section.id }}">
  <div class="page-width" style="max-width: 480px;">
    <h1 class="fs-section__title" style="text-align: center;">Create Account</h1>

    {%- form 'create_customer' -%}
      {%- if form.errors -%}
        <div style="color: var(--fs-color-sale); margin-bottom: var(--fs-space-md); text-align: center;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="fs-form-group">
        <label for="register-first-name">First name</label>
        <input type="text" id="register-first-name" name="customer[first_name]" autocomplete="given-name" class="fs-input">
      </div>

      <div class="fs-form-group">
        <label for="register-last-name">Last name</label>
        <input type="text" id="register-last-name" name="customer[last_name]" autocomplete="family-name" class="fs-input">
      </div>

      <div class="fs-form-group">
        <label for="register-email">Email</label>
        <input type="email" id="register-email" name="customer[email]" autocomplete="email" required class="fs-input">
      </div>

      <div class="fs-form-group">
        <label for="register-password">Password</label>
        <input type="password" id="register-password" name="customer[password]" autocomplete="new-password" required class="fs-input">
      </div>

      <button type="submit" class="fs-btn fs-btn--primary fs-btn--lg" style="width: 100%; margin-top: var(--fs-space-md);">Create Account</button>

      <p style="text-align: center; margin-top: var(--fs-space-lg); font-size: var(--fs-font-size-sm);">
        Already have an account? <a href="{{ routes.account_login_url }}">Sign in</a>
      </p>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "FS Register",
  "tag": "div",
  "class": "fs-register-section",
  "settings": []
}
{% endschema %}
